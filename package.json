{
  "name": "ccworktime",
  "version": "0.0.5",
  "type": "module",
  "description": "Calculate your Claude Code work time from session logs",
  "bin": {
    "ccworktime": "bin/ccworktime.js"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node bin/ccworktime.js",
    "today": "node bin/ccworktime.js --today",
    "yesterday": "node bin/ccworktime.js --yesterday",
    "week": "node bin/ccworktime.js --week",
    "month": "node bin/ccworktime.js --month",
    "test": "node --test test/*.test.js",
    "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 bin/ccworktime-build.js --outfile dist/ccworktime-darwin-arm64",
    "build:darwin-x64": "bun build --compile --target=bun-darwin-x64 bin/ccworktime-build.js --outfile dist/ccworktime-darwin-x64",
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 bin/ccworktime-build.js --outfile dist/ccworktime-linux-x64",
    "build:windows-x64": "bun build --compile --target=bun-windows-x64 bin/ccworktime-build.js --outfile dist/ccworktime-windows-x64.exe",
    "build": "npm run build:darwin-arm64 && npm run build:darwin-x64 && npm run build:linux-x64 && npm run build:windows-x64"
  },
  "keywords": [
    "claude",
    "claude-code",
    "work-time",
    "time-tracking",
    "productivity",
    "cli"
  ],
  "author": "ShahadIshraq",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShahadIshraq/ccworktime.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "picocolors": "^1.1.1"
  }
}
